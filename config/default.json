{
  "command": "run",
  "args": {
    "arms": 60,
    "players": 300,
    "exploration_cycles": 10,
    "strategy_steps": 1000,
    "seed": 123,
    "learner": "epsilon-greedy",
    "reward_distribution": "uniform",
    "mean_profile": "uniform",
    "mean_low": 0.5,
    "mean_high": 100.0,
    "std_profile": "constant",
    "std_value": 0.15,
    "top_offset": 0.35,
    "init_value": 0.5,
    "epsilon": 0.1,
    "epsilon_decay": 0.05,
    "epsilon_min": 0.01,
    "randomise_arms": true,
    "summary_json": "outputs/medium_run_summary.json",
    "table_prefix": "outputs/medium_run",
    "plot_prefix": "outputs/medium_run"
  }
}
